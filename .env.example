# -----------------------------------------------------------------------------
# このファイル (.env.example) は、本番環境へのデプロイ時に必要な環境変数の見本です。
# 実際のサーバーにデプロイする際は、このファイルを `.env` という名前にコピーして
# 以下の設定値を【あなたが実際に発行したキーやパスワード】に書き換えてください。
# -----------------------------------------------------------------------------

# ========== データベース設定 ==========
# Supabase等のPostgreSQL接続URL（パスワード部分を要変更）
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.supabase.co:5432/postgres"

# ========== 認証 (NextAuth) 設定 ==========
# アプリケーションのルートURL（本番環境では https://〜 に変更）
NEXTAUTH_URL="https://entry.meikun-pc.club"

# セッション暗号化用シークレットキー
# `openssl rand -base64 32` コマンド等で生成したランダムな文字列を設定
NEXTAUTH_SECRET="YOUR_RANDOM_SECRET_KEY_HERE="

# Google OAuth設定（Google Cloud Consoleで取得した認証情報）
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ========== メール送信 (nodemailer) 設定 ==========
# 自動送信メールのアカウント情報とアプリパスワード
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password_here"

# ========== システム制御設定 ==========
# ログインを許可する学校の指定ドメイン（例: niigata-meikun.ed.jp）
ALLOWED_DOMAIN="niigata-meikun.ed.jp"

# システム管理者として認めるGoogleアカウントのメールアドレス
# （スキャン画面や名簿を閲覧可能・カンマ区切りで複数指定可）
ADMIN_EMAILS="your_admin_email@gmail.com,another_admin@gmail.com"

# Cron APIのセキュリティトークン（定期実行ジョブを保護するためのシークレット）
CRON_SECRET="your_cron_secret_random_string"
