generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ▼NextAuth(ログイン機能)が使う標準テーブル
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ▼ユーザー情報（生徒）のテーブル
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // --- 入退室システム用の独自追加データ ---
  studentId     String? @unique // 学籍番号（メールアドレスから自動抽出）
  parentEmail   String? // 保護者のメールアドレス
  isRegistered  Boolean @default(false) // 初回登録が終わっているか？
  currentStatus String  @default("OUT") // 現在の状況（"IN"=在室 / "OUT"=退室）

  validFrom   DateTime? // 許可期間開始
  validUntil  DateTime? // 許可期間終了
  currentSeat String? // 現在使用中の座席番号

  logs AttendanceLog[] // 入退室履歴との紐付け
}

// ▼入退室の履歴テーブル
model AttendanceLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // "IN" (入室) または "OUT" (退室)
  timestamp DateTime @default(now()) // 打刻された時間
  remarks   String? // 手動退出などの備考

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ▼管理者操作ログテーブル
model AdminLog {
  id        String   @id @default(cuid())
  adminEmail String  // 操作した管理者のメールアドレス
  action    String   // 操作種別 (FORCE_LOGOUT, BULK_FORCE_LOGOUT, DELETE_USER, YEAR_RESET, etc.)
  details   String?  // 詳細（対象ユーザー名等）
  timestamp DateTime @default(now())
}

// ▼システム設定テーブル（座席レイアウト等）
model SystemSetting {
  key   String @id       // 設定キー（例: "seat_layout"）
  value String @db.Text  // 設定値（JSON文字列）
}
